# ======================
# DATABASE
# ======================
DATABASE_URL="postgresql://ea_user:ea_password_dev@localhost:5432/estuaire_achats"

# ======================
# AUTH / JWT
# ======================
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="change-me-refresh-in-production"
JWT_REFRESH_EXPIRES_IN="30d"

# ======================
# API
# ======================
API_PORT=3001
NODE_ENV=development
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3002
SELLER_URL=http://localhost:3003

# ======================
# REDIS
# ======================
REDIS_HOST=localhost
REDIS_PORT=6379

# ======================
# ELASTICSEARCH
# ======================
ELASTICSEARCH_URL=http://localhost:9200

# ======================
# PAIEMENTS — KPAY (MTN MoMo + Orange Money + Passerelle)
# Docs: https://docs.kpay.site
# Prefixe kpay_test_ = sandbox, kpay_live_ = production
# ======================
KPAY_API_KEY=kpay_test_xxxxxxxxxxxxxxxx
KPAY_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
KPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# ======================
# PAIEMENTS — GFSolutions (passerelle marchand)
# URL: https://pay.gfsolutions.cm
# ======================
GFS_PAYMENT_URL=https://pay.gfsolutions.cm
GFS_API_KEY=gfs_xxxxxxxxxxxxxxxx
GFS_API_SECRET=xxxxxxxxxxxxxxxx
GFS_CALLBACK_URL=http://localhost:3001/api/v1/payments/webhook/gfs

# ======================
# PAIEMENTS — PAYPAL
# ======================
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_CALLBACK_URL=

# ======================
# LIVRAISON — MERCI E
# ======================
MERCI_E_API_URL=http://localhost:8001
MERCI_E_API_TOKEN=

# ======================
# UPLOAD / S3
# ======================
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=estuaire-achats
S3_REGION=us-east-1

# ======================
# EMAIL (SMTP)
# ======================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@estuaireachats.com

# ======================
# SMS (pour OTP)
# ======================
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_ID=EstuaireAchats
